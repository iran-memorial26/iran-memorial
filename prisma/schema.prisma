generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Province {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  nameEn    String   @map("name_en")
  nameFa    String   @map("name_fa")
  nameDe    String   @map("name_de")
  latitude  Float
  longitude Float
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  cities City[]

  @@map("provinces")
}

model City {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  nameEn     String   @map("name_en")
  nameFa     String?  @map("name_fa")
  nameDe     String?  @map("name_de")
  provinceId Int      @map("province_id")
  province   Province @relation(fields: [provinceId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  victims Victim[] @relation("death_city")

  @@index([provinceId])
  @@map("cities")
}

model Event {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String    @unique
  dateStart          DateTime  @map("date_start") @db.Date
  dateEnd            DateTime? @map("date_end") @db.Date
  titleEn            String    @map("title_en")
  titleFa            String?   @map("title_fa")
  titleDe            String?   @map("title_de")
  descriptionEn      String?   @map("description_en")
  descriptionFa      String?   @map("description_fa")
  descriptionDe      String?   @map("description_de")
  estimatedKilledLow  Int?     @map("estimated_killed_low")
  estimatedKilledHigh Int?     @map("estimated_killed_high")
  tags               String[]
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  victims Victim[]
  sources Source[]
  photos  Photo[]

  @@map("events")
}

model Victim {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                  String    @unique
  nameLatin             String    @map("name_latin")
  nameFarsi             String?   @map("name_farsi")
  aliases               String[]
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  placeOfBirth          String?   @map("place_of_birth")
  gender                String?
  ethnicity             String?
  religion              String?
  photoUrl              String?   @map("photo_url")
  photoOriginalUrl      String?   @map("photo_original_url")

  // Life
  occupationEn          String?   @map("occupation_en")
  occupationFa          String?   @map("occupation_fa")
  occupationDe          String?   @map("occupation_de")
  education             String?
  familyInfo            Json?     @map("family_info")
  dreamsEn              String?   @map("dreams_en")
  dreamsFa              String?   @map("dreams_fa")
  dreamsDe              String?   @map("dreams_de")
  beliefsEn             String?   @map("beliefs_en")
  beliefsFa             String?   @map("beliefs_fa")
  beliefsDe             String?   @map("beliefs_de")
  personalityEn         String?   @map("personality_en")
  personalityFa         String?   @map("personality_fa")
  personalityDe         String?   @map("personality_de")
  quotes                String[]

  // Death
  dateOfDeath           DateTime? @map("date_of_death") @db.Date
  ageAtDeath            Int?      @map("age_at_death")
  placeOfDeath          String?   @map("place_of_death")
  province              String?
  cityId                Int?      @map("city_id")
  city                  City?     @relation("death_city", fields: [cityId], references: [id])
  causeOfDeath          String?   @map("cause_of_death")
  circumstancesEn       String?   @map("circumstances_en")
  circumstancesFa       String?   @map("circumstances_fa")
  circumstancesDe       String?   @map("circumstances_de")
  eventId               String?   @map("event_id") @db.Uuid
  event                 Event?    @relation(fields: [eventId], references: [id])
  eventContext          String?   @map("event_context")
  responsibleForces     String?   @map("responsible_forces")
  witnesses             String[]
  lastSeen              String?   @map("last_seen")

  // Aftermath
  burialLocation        String?   @map("burial_location")
  burialDate            DateTime? @map("burial_date") @db.Date
  burialCircumstancesEn String?   @map("burial_circumstances_en")
  burialCircumstancesFa String?   @map("burial_circumstances_fa")
  burialCircumstancesDe String?   @map("burial_circumstances_de")
  graveStatus           String?   @map("grave_status")
  familyPersecutionEn   String?   @map("family_persecution_en")
  familyPersecutionFa   String?   @map("family_persecution_fa")
  familyPersecutionDe   String?   @map("family_persecution_de")
  legalProceedings      String?   @map("legal_proceedings")
  tributes              String[]

  // Admin
  // Education (structured). The legacy `education` field above keeps the
  // free-text summary; these columns enable filterable views like
  // "all 2022 protest victims who studied at Sharif University".
  fieldOfStudy          String?   @map("field_of_study")
  universityName        String?   @map("university_name")
  universityCity        String?   @map("university_city")
  degreeLevel           String?   @map("degree_level") // bachelor|master|phd|undergraduate
  graduationYear        Int?      @map("graduation_year")
  // Online presence — captured to surface the victim's own voice on
  // their memorial page and to feed schema.org Person.sameAs so search
  // engines link the profile to verified social-graph identities.
  instagramHandle       String?   @map("instagram_handle")
  xHandle               String?   @map("x_handle")
  linkedinUrl           String?   @map("linkedin_url")
  githubHandle          String?   @map("github_handle")
  telegramHandle        String?   @map("telegram_handle")
  facebookUrl           String?   @map("facebook_url")
  youtubeChannelUrl     String?   @map("youtube_channel_url")
  websiteUrl            String?   @map("website_url")

  // Tier-2 goldstandard fields — added to make the archive HURIDOCS-
  // and FAIR-data-ready. Strict-typed structured signal that the legacy
  // free-text `circumstances_*` fields can't expose to filters.
  motherTongue              String?   @map("mother_tongue")
  prisonName                String?   @map("prison_name")
  prisonCellBlock           String?   @map("prison_cell_block")
  arrestDate                DateTime? @map("arrest_date") @db.Date
  arrestLocation            String?   @map("arrest_location")
  chargesEn                 String?   @map("charges_en")
  chargesFa                 String?   @map("charges_fa")
  lawyerName                String?   @map("lawyer_name")
  /// True when the victim's defence lawyer was themselves persecuted —
  /// the Nasrin-Sotoudeh / Mostafa-Daneshjoo pattern. Tracking this
  /// across the archive surfaces the regime's broader judicial-attack
  /// pattern, not just individual cases.
  lawyerPersecuted          Boolean   @default(false) @map("lawyer_persecuted")
  lastWordsEn               String?   @map("last_words_en")
  lastWordsFa               String?   @map("last_words_fa")
  internationalRecognition  String?   @map("international_recognition")
  /// True when a relative of the victim was also killed by the regime.
  /// Surfaces clan/family-line persecution (entire households executed
  /// in the 1988 massacres; siblings disappeared together in 2022).
  familyMemberKilled        Boolean   @default(false) @map("family_member_killed")
  disabilityStatus          String?   @map("disability_status")

  verificationStatus    String                                  @default("unverified") @map("verification_status")
  dataSource            String?                                 @map("data_source")
  notes                 String?
  searchVector          Unsupported("tsvector")?                @map("search_vector")
  createdAt             DateTime                                @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime                                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  sources           Source[]
  photos            Photo[]
  comments          Comment[]
  incomingRedirects VictimSlugRedirect[]

  @@index([slug])
  @@index([dateOfDeath])
  @@index([eventId])
  @@index([province])
  @@index([cityId])
  @@index([searchVector(ops: raw("gin_trgm_ops"))], map: "victims_search_vector_idx", type: Gin)
  @@map("victims")
}

model DataSource {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String              @unique
  name          String
  fullName      String?             @map("full_name")
  nameEn        String?             @map("name_en")
  nameFa        String?             @map("name_fa")
  nameDe        String?             @map("name_de")
  url           String?
  descriptionEn String?             @map("description_en") @db.Text
  descriptionFa String?             @map("description_fa") @db.Text
  descriptionDe String?             @map("description_de") @db.Text
  credibility   SourceCredibility   @default(MEDIUM)
  sourceType    SourceType?         @map("source_type")
  countryCode   String?             @map("country_code")
  foundedYear   Int?                @map("founded_year")
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  sources       Source[]

  @@map("data_sources")
}

model Source {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  victimId      String?     @map("victim_id") @db.Uuid
  victim        Victim?     @relation(fields: [victimId], references: [id], onDelete: Cascade)
  eventId       String?     @map("event_id") @db.Uuid
  event         Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dataSourceId  String?     @map("data_source_id") @db.Uuid
  dataSource    DataSource? @relation(fields: [dataSourceId], references: [id])
  url           String?
  name          String
  sourceType    String?     @map("source_type")
  publishedDate DateTime?   @map("published_date") @db.Date
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  @@index([dataSourceId])
  @@map("sources")
}

enum SourceCredibility {
  HIGH
  MEDIUM
  LOW
  UNVERIFIED
}

enum SourceType {
  NGO
  MEDIA
  GOVERNMENT
  ACADEMIC
  COMMUNITY
  MEMORIAL_PROJECT
  SOCIAL_MEDIA
  OFFICIAL_DOCUMENT
}

model Photo {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  victimId     String?  @map("victim_id") @db.Uuid
  victim       Victim?  @relation(fields: [victimId], references: [id], onDelete: Cascade)
  eventId      String?  @map("event_id") @db.Uuid
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url          String
  originalUrl  String?  @map("original_url")
  captionEn    String?  @map("caption_en")
  captionFa    String?  @map("caption_fa")
  sourceCredit String?  @map("source_credit")
  photoType       String    @default("portrait") @map("photo_type")
  isPrimary       Boolean   @default(false) @map("is_primary")
  sortOrder       Int       @default(0) @map("sort_order")
  isBroken        Boolean   @default(false) @map("is_broken")
  lastCheckedAt   DateTime? @map("last_checked_at") @db.Timestamptz()
  lastStatusCode  Int?      @map("last_status_code")
  contentHash     String?   @map("content_hash") @db.Char(64)
  phash           BigInt?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([victimId])
  @@index([eventId])
  @@index([victimId, isPrimary])
  @@index([isBroken])
  @@index([contentHash])
  @@index([phash])
  @@map("photos")
}

model Comment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  victimId       String   @map("victim_id") @db.Uuid
  victim         Victim   @relation(fields: [victimId], references: [id], onDelete: Cascade)
  authorName     String?  @map("author_name")
  content        String
  status         String   @default("pending") // pending, approved, rejected
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([victimId])
  @@index([status])
  @@map("comments")
}

model Submission {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  victimData      Json      @map("victim_data")
  submitterEmail  String?   @map("submitter_email")
  submitterName   String?   @map("submitter_name")
  status          String    @default("pending")
  reviewerNotes   String?   @map("reviewer_notes")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz()

  @@map("submissions")
}

model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String    @unique
  keyHash     String?   @unique @map("key_hash")
  name        String
  email       String?
  description String?
  rateLimit   Int       @default(1000) @map("rate_limit")
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()

  usageLogs ApiUsage[]
  webhooks  Webhook[]

  @@index([key])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId  String   @map("api_key_id") @db.Uuid
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  url       String
  events    String[] // ["victim.created", "submission.approved"]
  isActive  Boolean  @default(true) @map("is_active")
  secret    String   // HMAC signing secret
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([apiKeyId])
  @@map("webhooks")
}

model ApiUsage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Nullable: public MCP routes have no API key, log by IP only.
  apiKeyId   String?  @map("api_key_id") @db.Uuid
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint   String
  method     String
  statusCode Int      @map("status_code")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([apiKeyId])
  @@index([endpoint, createdAt])
  @@index([createdAt])
  @@map("api_usage")
}

model DuplicateCandidate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug1      String
  name1      String
  slug2      String
  name2      String
  similarity Float
  status     String   @default("pending") // pending, confirmed, dismissed
  scannedAt  DateTime @map("scanned_at") @db.Timestamptz()

  @@index([slug1])
  @@index([slug2])
  @@index([status])
  @@map("duplicate_candidates")
}

/// Permanent slug -> victim redirects. Used when two records that turned out
/// to be the same person were merged, or when a victim's slug changes. The
/// old slug is captured here so external links (Twitter, NGO reports, press)
/// continue to land on the surviving record via 308 redirect.
///
/// Populated by:
///   - tools/enricher/pipeline/dedup.py when merging a losing record into
///     a winning record (the losing slug -> winning victim id).
///   - manual operator action via SQL or future admin UI.
///
/// Consumed by: app/[locale]/victims/[slug]/page.tsx — on slug miss, look
/// up here and redirect() to the surviving slug.
model VictimSlugRedirect {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromSlug   String   @unique @map("from_slug")
  toVictimId String   @map("to_victim_id") @db.Uuid
  toVictim   Victim   @relation(fields: [toVictimId], references: [id], onDelete: Cascade)
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([toVictimId])
  @@map("victim_slug_redirects")
}

/// Blocklist of photo SHA-256 hashes that must never be attached to a victim.
/// Populated via the `enricher photo-block <hash>` CLI when an image is found
/// to be wrong, generic, NSFW, stolen, or otherwise unsuitable. Consulted by
/// the photo-mirror pipeline (skip on insert) and the photo-audit pipeline
/// (retroactive sweep + delete).
model BadPhotoHash {
  sha256        String   @id @db.Char(64)
  reason        String
  addedBy       String?  @map("added_by")
  firstSeenUrl  String?  @map("first_seen_url")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("bad_photo_hashes")
}
