# Database
DATABASE_URL="postgresql://memorial:memorial_dev_password@localhost:5433/iran_memorial"

# PostgreSQL (used by docker-compose)
POSTGRES_PASSWORD=memorial_dev_password

# NextAuth (for admin panel, Phase 2)
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# Optional: GitHub OAuth for admin login
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional: Webhook URL for admin notifications (supports Discord webhooks)
# Receives alerts for new submissions, comments, and conversions.
# WEBHOOK_URL=https://discord.com/api/webhooks/...
